# Source this file locally before running scripts/deploy_remote.sh.
#
# Example:
#   cp deploy/omniforum-remote-deploy.env.example deploy/omniforum-remote-deploy.env
#   edit deploy/omniforum-remote-deploy.env
#   set -a; . deploy/omniforum-remote-deploy.env; set +a
#   OMNIFORUM_DEPLOY_CONFIRM=yes scripts/deploy_remote.sh

OMNIFORUM_DEPLOY_HOST=forum.example.com
OMNIFORUM_DEPLOY_USER=deploy
OMNIFORUM_DEPLOY_PATH=/var/www/omniforum
OMNIFORUM_DEPLOY_SERVICE=omniforum
OMNIFORUM_DEPLOY_PUBLIC_URL=https://forum.example.com

# Optional SSH overrides.
OMNIFORUM_DEPLOY_SSH_OPTS=
OMNIFORUM_DEPLOY_SSH_BIN=ssh
OMNIFORUM_DEPLOY_SCP_BIN=scp

# Set to 0 if dependencies/service restart are handled externally.
OMNIFORUM_DEPLOY_INSTALL_DEPS=1
OMNIFORUM_DEPLOY_RESTART_SERVICE=1
OMNIFORUM_DEPLOY_RUN_READINESS=1
