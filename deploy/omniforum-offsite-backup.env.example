# Required target for scripts/offsite_backup.sh.
# Supported examples:
#   OMNIFORUM_OFFSITE_BACKUP_TARGET=local:/srv/omniforum-offsite
#   OMNIFORUM_OFFSITE_BACKUP_TARGET=rclone:backblaze:omniforum/backups
#   OMNIFORUM_OFFSITE_BACKUP_TARGET=s3://example-bucket/omniforum/backups
#   OMNIFORUM_OFFSITE_BACKUP_TARGET=rsync:backup@example.com:/srv/backups/omniforum
OMNIFORUM_OFFSITE_BACKUP_TARGET=

# Prefer a root-readable file on the host instead of putting the passphrase here.
OMNIFORUM_BACKUP_ENCRYPTION_PASSWORD_FILE=
OMNIFORUM_BACKUP_ENCRYPTION_PASSWORD=
OMNIFORUM_BACKUP_ROTATION=8
